import java.util.Scanner; 
 
public class PackageExpress { 
   public static void main(String[] args) { 
       Scanner scanner = new Scanner(System.in); 
 
       System.out.println("Welcome to Package Express. Please follow the instructions below."); 
 
       // 1. Get and validate package weight 
       System.out.print("Please enter the package weight: "); 
       double weight = scanner.nextDouble(); 
 
       if (weight > 50) { 
           System.out.println("Package too heavy to be shipped via Package Express. Have a good day."); 
           return; // Exit program 
       } 
 
       // 2. Get and validate package dimensions 
       System.out.print("Please enter the package width: "); 
       double width = scanner.nextDouble(); 
 
       System.out.print("Please enter the package height: "); 
       double height = scanner.nextDouble(); 
 
       System.out.print("Please enter the package length: "); 
       double length = scanner.nextDouble(); 
 
       if (width + height + length > 50) { 
           System.out.println("Package too big to be shipped via Package Express."); 
           return; // Exit program 
       } 
 
       // 3. Calculate and display the quote 
       // Formula: ((width * height * length) * weight) / 100 
       double dimensionsProduct = width * height * length; 
       double quote = (dimensionsProduct * weight) / 100; 

 

System.out.printf("Your estimated total for shipping this package is: $%.2f%n", quote); scanner.close(); } }
